local function wireESPRespawn(player)
    if _espCharConns[player] then
        pcall(function() _espCharConns[player]:Disconnect() end)
    end
    _espCharConns[player] = player.CharacterAdded:Connect(function()
        task.wait(0.5)
        if esp.enabled then createESPFor(player) end
    end)
    if player.Character and esp.enabled then createESPFor(player) end
end

local function unwireESP(player)
    removeESPFor(player)
    if _espCharConns[player] then
        pcall(function() _espCharConns[player]:Disconnect() end)
        _espCharConns[player] = nil
    end
end

-- Wire existing players
for _, p in ipairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then wireESPRespawn(p) end
end

Players.PlayerAdded:Connect(function(p)
    if p ~= LocalPlayer then wireESPRespawn(p) end
end)

Players.PlayerRemoving:Connect(function(p)
    unwireESP(p)
    if aim.target == p then aim.target = nil end
end)

-- Light 3-second refresh (catches any missed players)
local espRefreshTimer = 0
local function refreshESP(dt)
    espRefreshTimer += dt
    if espRefreshTimer < 3 then return end
    espRefreshTimer = 0
    for p in pairs(esp.objects) do
        if not p.Parent then removeESPFor(p) end
    end
    if not esp.enabled then return end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and not esp.objects[p] then
            createESPFor(p)
        end
    end
end

-- Update ESP visuals every frame (called from RenderStepped)
local function updateESP()
    if not esp.enabled then
        for _, d in pairs(esp.objects) do
            if d.boxFrame then d.boxFrame.Visible = false end
        end
        return
    end

    local root = getRoot()
    
    for player, data in pairs(esp.objects) do
        local char  = player.Character
        local hum   = char and char:FindFirstChild("Humanoid")
        local pRoot = char and char:FindFirstChild("HumanoidRootPart")

        if not char or not hum or hum.Health <= 0 or not pRoot then
            removeESPFor(player); continue
        end

        -- Keep adornees correct after respawn
        if data.hl.Adornee ~= char then
            data.hl.Adornee = char
            data.bb.Adornee = pRoot
        end

        -- Outline colour update
        local col = espColor(player)
        data.hl.OutlineColor = col

        -- Health + Distance info text
        local parts = {}
        if esp.health then
            parts[#parts+1] = string.format("HP %d/%d", mfloor(hum.Health), mfloor(hum.MaxHealth))
        end
        if esp.distance and root then
            parts[#parts+1] = mfloor((root.Position - pRoot.Position).Magnitude) .. "m"
        end
        data.il.Visible = #parts > 0
        data.il.Text    = table.concat(parts, "  ")

        -- 2D Box ESP using WorldToViewportPoint

       if esp.box then
            local sp, onScreen = Camera:WorldToViewportPoint(pRoot.Position)
            if sp.Z > 0 and onScreen then
                local scale = 1000 / (sp.Z + 1)
                local w  = scale * 1.1
                local h  = scale * 2.2
                local tx = sp.X - w * 0.5
                local ty = sp.Y - h * 0.5
                -- smooth lerp toward target position/size
                data._bx = data._bx and (data._bx + (tx - data._bx) * 0.3) or tx
                data._by = data._by and (data._by + (ty - data._by) * 0.3) or ty
                data._bw = data._bw and (data._bw + (w  - data._bw) * 0.3) or w
                data._bh = data._bh and (data._bh + (h  - data._bh) * 0.3) or h
                data.boxFrame.Visible  = true
                data.boxFrame.Position = UDim2.fromOffset(data._bx, data._by)
                data.boxFrame.Size     = UDim2.fromOffset(data._bw, data._bh)
                data.boxStroke.Color   = col   -- col = espColor(player) = team colour
                data.boxStroke.Thickness = esp.boxThick
            else
                data.boxFrame.Visible = false
                data._bx, data._by, data._bw, data._bh = nil, nil, nil, nil
            end
        else
            data.boxFrame.Visible = false
        end
    end  -- closes: for player, data in pairs(esp.objects) do
end      -- closes: local function updateESP()

