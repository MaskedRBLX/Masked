local StaffDetector = {
    Enabled = false,
    blacklistedClans = { 
    "gg", "gg2", "DV", "DV2", "DNO", "EASY", "AMRZ", 
    "U_V4", "TheTM", "KaMT", "CC", "CCER", "AXOMT", "JE",
    "GG", "dno", "easy", "amrz", "u_v4", "thetm", "kamt",
    "cc", "ccer", "axomt", "je"
},
    blacklistedUserIds = {
        1502104539, 3826146717, 4531785383, 1049767300, 4926350670,
        653085195,  184655415,  2752307430, 5087196317, 5744061325, 1536265275
    },
    joinedPlayers = {},
    connections   = {},
}

local function staffAlert(msg, duration, level)
    local color = level == "critical" and Color3.fromRGB(255,60,60)
               or level == "alert"    and Color3.fromRGB(255,160,30)
               or                         Color3.fromRGB(255,200,60)
    WindUI:Notify({ Title = "⚠️  STAFF ALERT", Content = msg, Duration = duration or 8 })
end

local function getPlayerRank(plr, groupId)
    local ok, r = pcall(function() return plr:GetRankInGroup(groupId) end)
    return ok and r or 0
end

local function checkFriendsList(plr)
    local list = {}
    local ok, pages = pcall(function() return Players:GetFriendsAsync(plr.UserId) end)
    if not ok then return list end
    for _ = 1, 3 do
        for _, f in pairs(pages:GetCurrentPage()) do tinsert(list, f.Id) end
        if pages.IsFinished then break end
        pcall(function() pages:AdvanceToNextPageAsync() end)
    end
    return list
end

local function onStaffDetected(plr, checkType)
    local level = checkType:find("clan") and "alert"
               or checkType:find("impossible") and "warning"
               or "critical"
    local msg = "⚠️ CHEATER OR DEV CLAN DETECTED\n" .. checkType:upper() .. ":  " .. plr.Name .. "  (" .. plr.UserId .. ")"
    WindUI:Notify({ Title = "Staff Detector", Content = msg, Duration = 10 })
    if othersState.staffLeave and bedwars and bedwars.PartyController then
        pcall(function() bedwars.PartyController:leaveParty() end)
    end
end

local function checkImpossibleJoin(plr, conn)
    if not plr:GetAttribute("Team") and plr:GetAttribute("Spectator") then
        if conn then conn:Disconnect() end
        local friends = checkFriendsList(plr)
        local fromFriend = nil
        for _, fid in ipairs(friends) do
            if StaffDetector.joinedPlayers[fid] then
                fromFriend = StaffDetector.joinedPlayers[fid]; break
            end
        end
        if not fromFriend then
            onStaffDetected(plr, "impossible_join"); return true
        else
            if othersState.staffDebug then
                staffAlert("Spectator " .. plr.Name .. " joined from " .. fromFriend, 4, "warning")
            end
        end
    end
    return false
end

local function onStaffPlayerAdded(plr)
    StaffDetector.joinedPlayers[plr.UserId] = plr.Name
    if plr == LocalPlayer then return end
    if table.find(StaffDetector.blacklistedUserIds, plr.UserId) then
        onStaffDetected(plr, "blacklisted_user"); return
    end
    if getPlayerRank(plr, 5774246) >= 100 then
        onStaffDetected(plr, "staff_role"); return
    end
    local conn
    conn = plr:GetAttributeChangedSignal("Spectator"):Connect(function()
        checkImpossibleJoin(plr, conn)
    end)
    tinsert(StaffDetector.connections, conn)
    checkImpossibleJoin(plr, conn)
    if not plr:GetAttribute("ClanTag") then
        local cc
        cc = plr:GetAttributeChangedSignal("ClanTag"):Connect(function()
            if cc then cc:Disconnect() end
            local tag = plr:GetAttribute("ClanTag") or ""
            if othersState.staffBlacklistClans and table.find(StaffDetector.blacklistedClans, tag) then
                onStaffDetected(plr, "blacklisted_clan_" .. tag:lower())
            end
        end)
        tinsert(StaffDetector.connections, cc)
    else
        local tag = plr:GetAttribute("ClanTag") or ""
        if othersState.staffBlacklistClans and table.find(StaffDetector.blacklistedClans, tag) then
            onStaffDetected(plr, "blacklisted_clan_" .. tag:lower())
        end
    end
end

local function enableStaffDetector()
    if StaffDetector.Enabled then return end
    table.clear(StaffDetector.joinedPlayers)
    for _, c in pairs(StaffDetector.connections) do pcall(function() c:Disconnect() end) end
    table.clear(StaffDetector.connections)
    tinsert(StaffDetector.connections, Players.PlayerAdded:Connect(onStaffPlayerAdded))
    tinsert(StaffDetector.connections, Players.PlayerRemoving:Connect(function(p)
        StaffDetector.joinedPlayers[p.UserId] = nil
    end))
    for _, p in ipairs(Players:GetPlayers()) do task.spawn(onStaffPlayerAdded, p) end
    StaffDetector.Enabled = true
    WindUI:Notify({ Title = "Staff Detector", Content = "Enabled — watching for staff joins.", Duration = 3 })
end

local function disableStaffDetector()
    if not StaffDetector.Enabled then return end
    for _, c in pairs(StaffDetector.connections) do pcall(function() c:Disconnect() end) end
    table.clear(StaffDetector.connections)
    table.clear(StaffDetector.joinedPlayers)
    StaffDetector.Enabled = false
end

-- Auto-enable on load if saved
if othersState.staffEnabled then task.defer(enableStaffDetector) end

