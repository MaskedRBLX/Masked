_G.MaskV4_PingStabilizer = P("ping_stabilizer", true)
_G.MaskV4_LowerPing      = P("ping_lower", false)

local _pingSmooth = 0
local _pingRaw    = 0

local function updatePing()
    pcall(function()
        _pingRaw = Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
    end)
    if not _pingRaw or _pingRaw ~= _pingRaw or _pingRaw < 0 then return end

    if _G.MaskV4_PingStabilizer then
        -- Exponential moving average — fast response, no fake lag reduction
        local alpha = 0.18
        _pingSmooth = _pingSmooth + alpha * (_pingRaw - _pingSmooth)
    else
        -- Raw value, no smoothing
        _pingSmooth = _pingRaw
    end
end
