local function _waitForChildOfType(obj, name, timeout, prop)
    local deadline = tick() + timeout
    local returned
    repeat
        returned = prop and obj[name] or obj:FindFirstChildOfClass(name)
        if returned or deadline < tick() then break end
        task.wait()
    until false
    return returned
end

