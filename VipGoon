-- TRIGGERBOT  —  Advanced FOV-based auto clicker
-- Works on Xeno, Solara, Synapse X, KRNL, Fluxus and more
-- ══════════════════════════════════════════════════════════════

-- ── Click method auto-detection ──
-- Detected once on first click, cached for all subsequent calls.
-- Tries every known executor API in order of reliability.
local _tbDetectedMethod = nil

local function tbLeftClick()
    -- Use cached method for speed after first detection
    if _tbDetectedMethod == 1 then
        pcall(function() mouse1press() end)
        task.wait(0.012)
        pcall(function() mouse1release() end)
        return
    elseif _tbDetectedMethod == 2 then
        pcall(function() mouse1click() end)
        return
    elseif _tbDetectedMethod == 3 then
        pcall(function()
            keypress(0x01)
            task.wait(0.012)
            keyrelease(0x01)
        end)
        return
    elseif _tbDetectedMethod == 4 then
        pcall(function()
            local vim = game:GetService("VirtualInputManager")
            vim:SendMouseButtonEvent(Mouse.X, Mouse.Y, 0, true, game, 1)
            task.wait(0.012)
            vim:SendMouseButtonEvent(Mouse.X, Mouse.Y, 0, false, game, 1)
        end)
        return
    end

    -- First call: detect working method
    -- Method 1: mouse1press / mouse1release  (Synapse X, Xeno, Wave)
    if typeof(mouse1press) == "function" then
        local ok = pcall(function() mouse1press() end)
        if ok then
            _tbDetectedMethod = 1
            task.wait(0.012)
            pcall(function() mouse1release() end)
            return
        end
    end

    -- Method 2: mouse1click  (KRNL, Fluxus shorthand)
    if typeof(mouse1click) == "function" then
        local ok = pcall(function() mouse1click() end)
        if ok then
            _tbDetectedMethod = 2
            return
        end
    end

    -- Method 3: keypress virtual LMB code 0x01  (Solara, some Fluxus builds)
    if typeof(keypress) == "function" and typeof(keyrelease) == "function" then
        local ok = pcall(function()
            keypress(0x01)
            task.wait(0.012)
            keyrelease(0x01)
        end)
        if ok then
            _tbDetectedMethod = 3
            return
        end
    end

    -- Method 4: VirtualInputManager  (universal fallback)
    _tbDetectedMethod = 4
    pcall(function()
        local vim = game:GetService("VirtualInputManager")
        vim:SendMouseButtonEvent(Mouse.X, Mouse.Y, 0, true, game, 1)
        task.wait(0.012)
        vim:SendMouseButtonEvent(Mouse.X, Mouse.Y, 0, false, game, 1)
    end)
end

-- ── Wall visibility check for triggerbot ──
local _tbWallParams = RaycastParams.new()
_tbWallParams.FilterType = Enum.RaycastFilterType.Exclude

local function tbCanSee(fromPos, toPos)
    -- ignoreWalls ON → always return true (shoot through anything)
    if triggerbot.ignoreWalls then return true end
    local char = getChar()
    _tbWallParams.FilterDescendantsInstances = char and { char } or {}
    local dir    = toPos - fromPos
    local result = workspace:Raycast(fromPos, dir, _tbWallParams)
    if not result then return true end  -- no hit → clear line of sight
    -- check if the hit instance is part of a player character (still counts as visible)
    local hit = result.Instance
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and hit:IsDescendantOf(p.Character) then
            return true
        end
    end
    return false  -- hit a wall or object — blocked
end

-- ── FOV circle enemy detection ──
-- Returns true if any valid enemy's body is inside the screen FOV circle.
-- Uses squared distance comparison to avoid expensive sqrt on every player.
local function tbEnemyInFOV()
    local root = getRoot(); if not root then return false end
    local myPos = root.Position

    -- Cache viewport center once per call (avoids repeated property reads)
    local vp   = Camera.ViewportSize
    local cx   = vp.X * 0.5
    local cy   = vp.Y * 0.5
    local fovR = triggerbot.fov
    local fovR2 = fovR * fovR  -- squared — avoids sqrt per enemy

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end

        -- Team check: reuse Kill Aura's team check setting so they match
        if ka.teamCheck and plr.Team and LocalPlayer.Team
        and plr.Team == LocalPlayer.Team then continue end

        local char  = plr.Character;                       if not char  then continue end
        local hum   = char:FindFirstChild("Humanoid");     if not hum   then continue end
        if hum.Health <= 0 then continue end
        local pRoot = char:FindFirstChild("HumanoidRootPart"); if not pRoot then continue end

        -- 3D distance gate FIRST — cheapest possible rejection
        local dist3d = (myPos - pRoot.Position).Magnitude
        if dist3d > triggerbot.range then continue end

        -- Wall check (respects ignore walls toggle)
        if not tbCanSee(myPos, pRoot.Position) then continue end

        -- Project to screen space
        local sp, onScreen = Camera:WorldToViewportPoint(pRoot.Position)
        if not onScreen or sp.Z <= 0 then continue end

        -- 2D squared distance from screen centre — no sqrt needed
        local dx = sp.X - cx
        local dy = sp.Y - cy
        if dx * dx + dy * dy <= fovR2 then
            return true   -- enemy found inside FOV — fire!
        end
    end
    return false
end

-- ── Triggerbot main loop (Heartbeat-based for precise CPS timing) ──
-- Heartbeat fires every frame and accumulates delta time.
-- This gives far more accurate CPS than task.spawn + task.wait.
local _tbTimer = 0

RunService.Heartbeat:Connect(function(dt)
    if not triggerbot.enabled then
        _tbTimer = 0
        return
    end
    if triggerbot.swordOnly and not checkSwordEquipped() then
        _tbTimer = 0
        return
    end

    local interval = 1 / math.max(triggerbot.cps, 1)
    _tbTimer += dt

    if _tbTimer < interval then return end
    _tbTimer = _tbTimer - interval  -- subtract rather than reset, keeps leftover time

    -- Only check FOV and click when the interval has elapsed
    if tbEnemyInFOV() then
        task.spawn(tbLeftClick)  -- spawn so it doesn't block the Heartbeat
    end
end)

