    local distLabel = Instance.new("TextLabel", bb)
    distLabel.BackgroundTransparency = 1
    distLabel.Size                   = UDim2.new(0, 42, 1, 0)
    distLabel.Position               = UDim2.new(0, iconW + 2, 0, 0)
    distLabel.TextColor3             = Color3.fromRGB(255, 255, 255)
    distLabel.TextStrokeTransparency = 0.35
    distLabel.TextStrokeColor3       = Color3.fromRGB(0,0,0)
    distLabel.Font                   = Enum.Font.GothamBold
    distLabel.TextSize               = 11
    distLabel.Text                   = ""
    distLabel.TextXAlignment         = Enum.TextXAlignment.Left
    distLabel.Visible                = kitesp.showDist

    kitesp.objects[part] = { bb = bb, distLabel = distLabel, part = part }
end

local function removeKitBillboard(part)
    local data = kitesp.objects[part]
    if data then
        pcall(function() data.bb:Destroy() end)
        kitesp.objects[part] = nil
    end
end

local function rebuildKitESP()
    clearKitESP()
    if not kitesp.folder or not kitesp.folder.Parent then
        kitesp.folder = Instance.new("Folder")
        kitesp.folder.Name   = "MaskV4_KitESP"
        kitesp.folder.Parent = workspace
    end
    for tag, data in pairs(KIT_TAGS) do
        local icon = data.icon
        if data.useCollection then
            local c1 = CollectionService:GetInstanceAddedSignal(tag):Connect(function(v)
                if not kitesp.enabled then return end
                local part = v:IsA("Model") and v.PrimaryPart or v
                if part then makeKitBillboard(part, icon) end
            end)
            local c2 = CollectionService:GetInstanceRemovedSignal(tag):Connect(function(v)
                local part = v:IsA("Model") and v.PrimaryPart or v
                if part then removeKitBillboard(part) end
            end)
            tinsert(kitesp.conns, c1); tinsert(kitesp.conns, c2)
            for _, v in ipairs(CollectionService:GetTagged(tag)) do
                local part = v:IsA("Model") and v.PrimaryPart or v
                if part then makeKitBillboard(part, icon) end
            end
        else
            local tagCopy = tag
            local c1 = workspace.ChildAdded:Connect(function(v)
                if not kitesp.enabled then return end
                if v.Name == tagCopy and v:IsA("Model") then
                    task.wait()
                    if v.PrimaryPart then makeKitBillboard(v.PrimaryPart, icon) end
                end
            end)
            local c2 = workspace.ChildRemoved:Connect(function(v)
                if v.Name == tagCopy and v:IsA("Model") then
                    if v.PrimaryPart then removeKitBillboard(v.PrimaryPart) end
                end
            end)
            tinsert(kitesp.conns, c1); tinsert(kitesp.conns, c2)
            for _, v in ipairs(workspace:GetChildren()) do
                if v.Name == tag and v:IsA("Model") and v.PrimaryPart then
                    makeKitBillboard(v.PrimaryPart, icon)
                end
            end
        end
    end
end

if kitesp.enabled then task.defer(rebuildKitESP) end

