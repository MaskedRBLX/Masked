-- ══════════════════════════════════════════════════════════════
local function pressAndReleaseKey(keyCodeStr, holdTime)
    holdTime = holdTime or 0.05
    local vimOk = pcall(function()
        local vim = game:GetService("VirtualInputManager")
        vim:SendKeyEvent(true,  keyCodeStr, false, game)
        task.wait(holdTime)
        vim:SendKeyEvent(false, keyCodeStr, false, game)
    end)
    if not vimOk then
        pcall(function()
            local kc = Enum.KeyCode[keyCodeStr]
            if kc then
                keypress(kc.Value)
                task.wait(holdTime)
                keyrelease(kc.Value)
            end
        end)
    end
end
local autoKitRunning = false

task.spawn(function()
    while true do
        task.wait(0.15)
        if not othersState.autoKit then
            autoKitRunning = false
            continue
        end

        -- METHOD 2: pure spam, no distance check at all
        if othersState.autoKitMethod == "spam" then
            pressAndReleaseKey(othersState.autoKitKey, 2.0)
            task.wait(0.1)
            continue
        end

        -- METHOD 1: only press when near a KitESP icon
        if not kitesp.enabled then continue end
        local root = getRoot(); if not root then continue end
        local lpPos = root.Position
        local nearbyPart = nil
        for part in pairs(kitesp.objects) do
            if part and part.Parent then
                if (lpPos - part.Position).Magnitude <= othersState.autoKitDist then
                    nearbyPart = part; break
                end
            end
        end
        if nearbyPart and not autoKitRunning then
            autoKitRunning = true
            task.spawn(function()
                while othersState.autoKit and othersState.autoKitMethod ~= "spam" do
                    pressAndReleaseKey(othersState.autoKitKey, 2.0)
                    task.wait(0.1)
                    local r = getRoot(); if not r then break end
                    local still = false
                    for part in pairs(kitesp.objects) do
                        if part and part.Parent and (r.Position - part.Position).Magnitude <= othersState.autoKitDist then
                            still = true; break
                        end
                    end
                    if not still then break end
                end
                autoKitRunning = false
            end)
        elseif not nearbyPart then
            autoKitRunning = false
        end
    end
end)

