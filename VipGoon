-- KILL AURA — target priority scoring
-- ══════════════════════════════════════════════════════════════
local function priorityScore(hp, maxHp, dist)
    local p = ka.priority
    if p == "distance" then
        return dist                          -- lower = closer = better
    elseif p == "health" then
        return hp                            -- lower = more hurt = better
    elseif p == "threat" then
        local hpRatio = (maxHp > 0) and (hp / maxHp) or 1
        return hpRatio * (dist / 30)         -- lower = more dangerous = better
    end
    return dist
end

-- Pre-allocated to avoid per-cycle GC pressure
local _kaTargets = {}

-- ══════════════════════════════════════════════════════════════
-- KILL AURA — main loop
-- ══════════════════════════════════════════════════════════════
-- ══════════════════════════════════════════════════════════════
-- KILL AURA  —  Enhanced main loop
-- Uses Heartbeat accumulation for precise Hz timing (no task.wait drift)
-- Entity scan: range-squared pre-filter, priority scoring, wall check
-- ══════════════════════════════════════════════════════════════

-- Pre-compute range squared so we avoid sqrt in the hot loop
-- Updated every cycle since ka.range can change at any time
local _kaTimer      = 0
local _kaRangeSq    = ka.range * ka.range
local _kaLastRange  = ka.range

-- Swap buffer: two tables to avoid GC pressure from tinsert each cycle
local _kaBuf = {}

RunService.Heartbeat:Connect(function(dt)
    -- ── Timing: Hz accumulator + optional delay ──
    local interval
    if ka.delay > 0 then
        interval = ka.delay / 1000   -- delay in ms → seconds
    else
        interval = math.max(1 / ka.hz, 0.004)   -- Hz rate, capped at 250 Hz
    end

    _kaTimer += dt
    if _kaTimer < interval then return end
    _kaTimer = _kaTimer - interval   -- subtract to carry over leftover time (no drift)

    -- ── Early exits (fastest checks first) ──
    if not ka.enabled                                      then return end
    if not clickOkay()                                     then return end
    if ka.requireMouse and not lmbHeld                     then return end
    if ka.limitToItems and not checkSwordEquipped()        then return end

    local root = getRoot();           if not root     then return end
    local localHum = getHumanoid();   if not localHum then return end
    if localHum.Health <= 0                                then return end

    local rootCF = root.CFrame
    local lpPos  = rootCF.Position

    -- Update range-squared cache only when setting changed
    if ka.range ~= _kaLastRange then
        _kaLastRange = ka.range
        _kaRangeSq   = ka.range * ka.range
    end

    -- ══════════════════════════════════════════════════
    -- METHOD 1: swingSwordAtMouse  (Vape native — primary)
    -- ══════════════════════════════════════════════════
    if ka.useSwingMode and bedwarsReady
    and bedwars.SwordController
    and bedwars.SwordController.swingSwordAtMouse then

        table.clear(_kaBuf)

        local myTeam = LocalPlayer.Team

        for _, ent in ipairs(entitylib.List) do
            -- Fast rejection: targetable + alive
            if not ent.Targetable              then continue end
            if not entitylib.isVulnerable(ent) then continue end

            -- Team check
            if ka.teamCheck and ent.Player then
                local et = ent.Player.Team
                if myTeam and et and et == myTeam then continue end
            end

            local pRoot = ent.RootPart; if not pRoot then continue end
            local pPos  = pRoot.Position

            -- Squared distance rejection (avoids sqrt)
            local dx = pPos.X - lpPos.X
            local dy = pPos.Y - lpPos.Y
            local dz = pPos.Z - lpPos.Z
            local distSq = dx*dx + dy*dy + dz*dz
            if distSq > _kaRangeSq then continue end

            -- Angle cone check
            if not inAngleCone(rootCF, pPos) then continue end

            -- Wall check
            if not isVisible(lpPos, pPos) then continue end

            local dist  = math.sqrt(distSq)
            local score = priorityScore(ent.Health, ent.MaxHealth, dist)
            _kaBuf[#_kaBuf + 1] = { pPos = pPos, score = score }
        end

        if #_kaBuf == 0 then return end

        -- Sort only if more than one target (avoids sort overhead for common single-target case)
        if #_kaBuf > 1 then
            table.sort(_kaBuf, function(a, b) return a.score < b.score end)
        end

        -- Swing at the best target
        local best    = _kaBuf[1]
        local savedCF = Camera.CFrame
        local swingCF = CFrame.new(savedCF.Position, best.pPos)

        Camera.CFrame = swingCF
        pcall(function() bedwars.SwordController:swingSwordAtMouse() end)
        -- Restore camera immediately to prevent visible snap
        Camera.CFrame = savedCF

    -- ══════════════════════════════════════════════════
    -- METHOD 2: FireServer fallback  (with HitFix)
    -- ══════════════════════════════════════════════════
    else
        local net   = getKANet()
        local sword = getSwordItem()
        if not net or not sword then return end

        _rayFilterDirty = true
        table.clear(_kaBuf)

        local myTeam = LocalPlayer.Team

        -- Real players
        for _, p in ipairs(Players:GetPlayers()) do
            if p == LocalPlayer then continue end
            if ka.teamCheck and myTeam and p.Team == myTeam then continue end

            local char  = p.Character;                          if not char then continue end
            local hum   = char:FindFirstChild("Humanoid");      if not hum  then continue end
            if hum.Health <= 0 then continue end
            local pRoot = char:FindFirstChild("HumanoidRootPart"); if not pRoot then continue end

            local pPos = pRoot.Position

            -- Squared distance fast reject
            local dx = pPos.X - lpPos.X
            local dy = pPos.Y - lpPos.Y
            local dz = pPos.Z - lpPos.Z
            local distSq = dx*dx + dy*dy + dz*dz
            if distSq > _kaRangeSq then continue end

            if not inAngleCone(rootCF, pPos) then continue end
            if not isVisible(lpPos, pPos)    then continue end

            local dist  = math.sqrt(distSq)
            local score = priorityScore(hum.Health, hum.MaxHealth, dist)
            _kaBuf[#_kaBuf + 1] = { char = char, pPos = pPos, score = score }
        end

        -- NPCs from entitylib
        for _, ent in ipairs(entitylib.List) do
            if not ent.NPC                     then continue end
            if not entitylib.isVulnerable(ent) then continue end

            local pRoot = ent.RootPart; if not pRoot then continue end
            local pPos  = pRoot.Position

            local dx = pPos.X - lpPos.X
            local dy = pPos.Y - lpPos.Y
            local dz = pPos.Z - lpPos.Z
            local distSq = dx*dx + dy*dy + dz*dz
            if distSq > _kaRangeSq then continue end

            if not inAngleCone(rootCF, pPos) then continue end
            if not isVisible(lpPos, pPos)    then continue end

            local dist  = math.sqrt(distSq)
            local score = priorityScore(ent.Health, ent.MaxHealth, dist)
            _kaBuf[#_kaBuf + 1] = { char = ent.Character, pPos = pPos, score = score }
        end

        if #_kaBuf == 0 then return end
        if #_kaBuf > 1 then
            table.sort(_kaBuf, function(a, b) return a.score < b.score end)
        end

        local best = _kaBuf[1]
        local pPos = best.pPos
        local fireSelfPos = lpPos

        if ka.hitfix then
            local distance         = (lpPos - pPos).Magnitude
            local pingCompensation = math.min(getPingMs() / 1000 * 50, 8)
            local adjustmentDist   = math.max(distance - 12, 0) + pingCompensation
            if adjustmentDist > 0 then
                local direction = CFrame.lookAt(lpPos, pPos).LookVector
                fireSelfPos = lpPos + (direction * adjustmentDist)
            end
        end

        if best.char then
            pcall(function()
                local args = {{
                    entityInstance = best.char,
                    chargedAttack  = { chargeRatio = 0 },
                    validate = {
                        targetPosition = { value = pPos },
                        selfPosition   = { value = fireSelfPos },
                    },
                    weapon = sword,
                }}
                -- FireServer is already pcall'd via HitFix hook
                return (select(2, pcall(net.FireServer, net, unpack(args))))
            end)
        end
    end
end)
