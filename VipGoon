local function isAimEnemy(p)
    if not aim.teamCheck then return true end
    return p.Team ~= LocalPlayer.Team or p.Team == nil or LocalPlayer.Team == nil
end






local function aimClickOkay()
    if not aim.clickOnly then return true end
    if aim.clickLMB and lmbHeld then return true end
    if aim.clickRMB and rmbHeld then return true end
    if aim.clickX1  and x1Held  then return true end
    if aim.clickX2  and x2Held  then return true end
    return false
end

local function getAimTarget()
    local root = getRoot(); if not root then return nil end
    local bestDist, best = aim.range, nil
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer or not isAimEnemy(p) then continue end
        local char  = p.Character
        local hum   = char and char:FindFirstChild("Humanoid")
        local pRoot = char and char:FindFirstChild("HumanoidRootPart")
        if not char or not hum or hum.Health <= 0 or not pRoot then continue end
        local d = (root.Position - pRoot.Position).Magnitude
        if d < bestDist then bestDist = d; best = p end
    end
    return best
end


local function doAimAssist()
    if not aim.enabled then return end
    if not aimClickOkay() then return end

    local root = getRoot(); if not root then return end

    if aim.method == "distance" then
        aim.target = getAimTarget()

    elseif aim.method == "target" then
        if aim.target then
            local char  = aim.target.Character
            local hum   = char and char:FindFirstChild("Humanoid")
            local pRoot = char and char:FindFirstChild("HumanoidRootPart")
            if not hum or hum.Health <= 0 then
                aim.target = nil
            elseif pRoot and (root.Position - pRoot.Position).Magnitude > aim.range then
                aim.target = nil
            end
        end
        if not aim.target then aim.target = getAimTarget() end

    elseif aim.method == "health" then
        local lowestHP = math.huge; aim.target = nil
        for _, p in ipairs(Players:GetPlayers()) do
            if p == LocalPlayer or not isAimEnemy(p) then continue end
            local char  = p.Character
            local hum   = char and char:FindFirstChild("Humanoid")
            local pRoot = char and char:FindFirstChild("HumanoidRootPart")
            if not char or not hum or hum.Health <= 0 or not pRoot then continue end
            if (root.Position - pRoot.Position).Magnitude > aim.range then continue end
            if hum.Health < lowestHP then lowestHP = hum.Health; aim.target = p end
        end
    end

    if not aim.target then return end
    local char = aim.target.Character; if not char then return end
    local bone = char:FindFirstChild("HumanoidRootPart")
               or char:FindFirstChild("UpperTorso")
               or char:FindFirstChild("Torso")
    if not bone then return end

    local targetCF = cf3new(Camera.CFrame.Position, bone.Position)
    if aim.shakeAmt > 0 then
        aim._shakeT = (aim._shakeT or 0) + aim.shakeSpeed * 0.016
        targetCF = targetCF * CFrame.Angles(0, math.sin(aim._shakeT) * math.rad(aim.shakeAmt), 0)
    end
    Camera.CFrame = aim.smoothing < 0.01 and targetCF
                 or Camera.CFrame:Lerp(targetCF, 1 - aim.smoothing)
end
