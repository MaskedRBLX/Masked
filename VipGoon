-- PROFILE APPLY  (applies a parsed profile dict live)
-- ══════════════════════════════════════════════════════════════
local function applyProfileData(data)
    if not data then return end
    if data.ka_enabled      ~= nil then ka.enabled      = data.ka_enabled      end
    if data.ka_range        ~= nil then ka.range        = data.ka_range        end
    if data.ka_teamCheck    ~= nil then ka.teamCheck    = data.ka_teamCheck    end
    if data.ka_delay        ~= nil then ka.delay        = data.ka_delay        end
    if data.ka_angle        ~= nil then ka.angleDeg     = data.ka_angle        end
    if data.ka_requireMouse ~= nil then ka.requireMouse = data.ka_requireMouse end
    if data.ka_limitToItems ~= nil then ka.limitToItems = data.ka_limitToItems end
    if data.ka_ignoreWalls  ~= nil then ka.ignoreWalls  = data.ka_ignoreWalls  end
    if data.ka_hitfix       ~= nil then ka.hitfix = data.ka_hitfix; HitFixEnabled = ka.hitfix end
    if data.ka_hitboxes     ~= nil then
        ka.hitboxes = data.ka_hitboxes
        if bedwarsReady then applySwordHitbox(ka.hitboxes, ka.hitboxExpand) end
    end
    if data.ka_hitboxExpand ~= nil then
        ka.hitboxExpand = data.ka_hitboxExpand
        if ka.hitboxes and bedwarsReady then applySwordHitbox(true, ka.hitboxExpand) end
    end
    if data.ka_useSwingMode ~= nil then ka.useSwingMode = data.ka_useSwingMode end
    if data.ka_priority     ~= nil then ka.priority     = data.ka_priority     end
    if data.ka_kaKey        ~= nil then ka.kaKey        = data.ka_kaKey        end
    if data.ka_aimKey       ~= nil then ka.aimKey       = data.ka_aimKey       end
    if data.ka_clickOnly    ~= nil then ka.clickOnly    = data.ka_clickOnly    end
    if data.ka_clickLMB     ~= nil then ka.clickLMB     = data.ka_clickLMB     end
    if data.ka_clickRMB     ~= nil then ka.clickRMB     = data.ka_clickRMB     end
    if data.ka_clickX1      ~= nil then ka.clickX1      = data.ka_clickX1      end
    if data.ka_clickX2      ~= nil then ka.clickX2      = data.ka_clickX2      end
    if data.kb_enabled      ~= nil then kb.enabled      = data.kb_enabled      end
    if data.kb_strength     ~= nil then kb.strength     = data.kb_strength     end
    if data.aim_enabled     ~= nil then
        aim.enabled = data.aim_enabled
        if not aim.enabled then aim.target = nil end
    end
    if data.aim_teamCheck   ~= nil then aim.teamCheck   = data.aim_teamCheck   end
    if data.aim_range       ~= nil then aim.range       = data.aim_range       end
    if data.aim_smoothing   ~= nil then aim.smoothing   = data.aim_smoothing   end
    if data.esp_enabled     ~= nil then esp.enabled     = data.esp_enabled     end
    if data.esp_health      ~= nil then esp.health      = data.esp_health      end
    if data.esp_distance    ~= nil then esp.distance    = data.esp_distance    end
    if data.esp_box         ~= nil then esp.box         = data.esp_box         end
    if data.esp_boxThick    ~= nil then esp.boxThick    = data.esp_boxThick    end
    -- fps state saved but NEVER auto-apply lighting on load
    if data.fps_greysky     ~= nil then fpsState.greysky     = data.fps_greysky     end
    if data.fps_greyplayers ~= nil then fpsState.greyplayers = data.fps_greyplayers end
    if data.fps_noshadows   ~= nil then fpsState.noshadows   = data.fps_noshadows   end
    if data.fps_noneon      ~= nil then fpsState.noneon      = data.fps_noneon      end
    if data.fps_noparticles ~= nil then fpsState.noparticles = data.fps_noparticles end
    if data.kitesp_enabled  ~= nil then
        local was = kitesp.enabled
        kitesp.enabled = data.kitesp_enabled
        if kitesp.enabled and not was then rebuildKitESP()
        elseif not kitesp.enabled and was then clearKitESP() end
    end
    if data.kitesp_iconSize ~= nil then
        kitesp.iconSize = data.kitesp_iconSize
        updateKitIconSizes(kitesp.iconSize)
    end
    if data.kitesp_showDist ~= nil then kitesp.showDist = data.kitesp_showDist end
    if data.hud_enabled     ~= nil then hud.enabled     = data.hud_enabled     end
    collectAndSave()
end

